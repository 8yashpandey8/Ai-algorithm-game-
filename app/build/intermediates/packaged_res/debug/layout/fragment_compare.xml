<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:background="?attr/colorSurface"
    android:padding="16dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Algorithm Race"
        android:textAppearance="?attr/textAppearanceHeadlineMedium"
        android:textStyle="bold"
        android:textColor="?attr/colorPrimary"/>
        
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Select a game and two algorithms to compare their performance side-by-side."
        android:textAppearance="?attr/textAppearanceBodyMedium"
        android:layout_marginBottom="16dp"
        android:textColor="?attr/colorOnSurfaceVariant"/>

    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"
        app:cardCornerRadius="12dp"
        app:cardElevation="2dp">
        
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="12dp">
            
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Select Game:"
                android:textStyle="bold"
                android:layout_marginBottom="4dp"/>
                
            <Spinner
                android:id="@+id/spinner_compare_game"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:background="@drawable/bg_glassmorphism"
                android:layout_marginBottom="8dp"/>
                
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_start_race"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Start Race"
                app:cornerRadius="8dp" />
                
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="horizontal"
        android:baselineAligned="false">

        <!-- Algorithm 1 Column -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:paddingEnd="8dp">

            <Spinner
                android:id="@+id/spinner_algo1"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:background="@drawable/bg_glassmorphism"
                android:layout_marginBottom="8dp"/>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                app:cardBackgroundColor="?attr/colorSecondaryContainer"
                app:cardCornerRadius="12dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:padding="12dp">
                    
                    <TextView
                        android:id="@+id/tv_status1"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Waiting"
                        android:textStyle="bold"
                        android:textColor="?attr/colorOnSecondaryContainer"
                        android:gravity="center"
                        android:layout_marginBottom="12dp"/>
                        
                    <TextView
                        android:id="@+id/tv_metrics1"
                        android:layout_width="match_parent"
                        android:layout_height="0dp"
                        android:layout_weight="1"
                        android:text="Nodes Explored: 0\nPath Cost: 0\nMax Depth: 0"
                        android:textColor="?attr/colorOnSecondaryContainer"
                        android:textSize="14sp"/>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>

        <!-- Algorithm 2 Column -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:paddingStart="8dp">

            <Spinner
                android:id="@+id/spinner_algo2"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:background="@drawable/bg_glassmorphism"
                android:layout_marginBottom="8dp"/>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                app:cardBackgroundColor="?attr/colorPrimaryContainer"
                app:cardCornerRadius="12dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:padding="12dp">
                    
                    <TextView
                        android:id="@+id/tv_status2"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Waiting"
                        android:textStyle="bold"
                        android:textColor="?attr/colorOnPrimaryContainer"
                        android:gravity="center"
                        android:layout_marginBottom="12dp"/>
                        
                    <TextView
                        android:id="@+id/tv_metrics2"
                        android:layout_width="match_parent"
                        android:layout_height="0dp"
                        android:layout_weight="1"
                        android:text="Nodes Explored: 0\nPath Cost: 0\nMax Depth: 0"
                        android:textColor="?attr/colorOnPrimaryContainer"
                        android:textSize="14sp"/>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>

    </LinearLayout>
    
    <TextView
        android:id="@+id/tv_winner"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text=""
        android:layout_marginTop="16dp"
        android:gravity="center"
        android:textStyle="bold"
        android:textSize="16sp"
        android:textColor="?attr/colorPrimary"/>

</LinearLayout>
